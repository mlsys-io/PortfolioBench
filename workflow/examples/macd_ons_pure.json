{
  "apiVersion": "lumid/v1",
  "kind": "PortbenchWorkflow",
  "metadata": {
    "name": "macd-ons-pure",
    "annotations": {
      "description": "MACD alpha with MACD-cross signals and pure ONS portfolio weights."
    }
  },
  "spec": {
    "stages": {
      "alpha": {
        "taskType": "alpha",
        "params": {
          "type": "macd"
        }
      },
      "strategy": {
        "taskType": "strategy",
        "dependsOn": ["alpha"],
        "params": {
          "type": "macd"
        }
      },
      "portfolio": {
        "taskType": "portfolio",
        "dependsOn": ["strategy"],
        "params": {
          "type": "ons",
          "ons": {
            "eta": 0.0,
            "beta": 1.0,
            "delta": 0.125
          }
        }
      }
    },
    "backtest": {
      "pairs": ["BTC/USDT", "ETH/USDT", "SOL/USDT"],
      "timeframe": "1d",
      "initial_capital": 50000
    }
  }
}
