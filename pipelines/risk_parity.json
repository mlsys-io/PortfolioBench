{
  "name": "Risk Parity Multi-Asset Portfolio",
  "version": "1.0",
  "description": "Risk parity allocation across crypto, equities, bonds, and commodities",
  
  "alpha": [
    {
      "type": "ema",
      "params": {
        "fast_period": 12,
        "slow_period": 26,
        "exit_period": 9
      }
    }
  ],
  
  "strategies": [
    {
      "type": "ema_cross",
      "alpha_factors": [
        { "type": "ema" }
      ],
      "params": {}
    }
  ],
  
  "portfolio": {
    "algorithm": "risk_parity",
    "strategies": [
      { "type": "ema_cross" }
    ],
    "strategy_weights": {
      "ema_cross": 1.0
    },
    "rebalance_frequency": "monthly",
    "params": {
      "target_vol": 0.12,
      "min_weight": 0.05,
      "max_weight": 0.35
    }
  },
  
  "backtest": {
    "timerange": "20240101-20260101",
    "timeframe": "1d",
    "pairs": [
      "BTC/USDT",
      "ETH/USDT",
      "SPY/USD",
      "TLT/USD",
      "GLD/USD",
      "USO/USD",
      "DXY/USD"
    ],
    "initial_capital": 100000.0,
    "dry_run_wallet": null,
    "enable_trading_mode": false
  },
  
  "data": {
    "data_dir": "./user_data/data/usstock",
    "exchange": "portfoliobench",
    "cache_dir": "./user_data/cache"
  },
  
  "enable_validation": true,
  "validate_data_integrity": true,
  "validate_alpha_signals": true,
  "validate_strategy_signals": true,
  "validate_portfolio_weights": true,
  
  "output_dir": "./output/risk_parity",
  "export_weights": true,
  "export_backtest_results": true,
  "export_metrics": true,
  "verbose": false
}
